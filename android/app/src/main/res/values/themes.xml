<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.PharmAlert" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_600</item>
        <item name="colorPrimaryVariant">@color/brand_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_500</item>
        <item name="colorSecondaryVariant">@color/brand_400</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/brand_700</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowBackground">@color/gray_50</item>
        <!-- TextInputLayout colors -->
        <item name="textInputStyle">@style/Widget.PharmAlert.TextInputLayout</item>
        <!-- Force text colors for input fields -->
        <item name="android:textColorPrimary">@color/gray_900</item>
        <item name="android:textColorSecondary">@color/gray_600</item>
        <item name="android:textColorHint">@color/gray_500</item>
    </style>

    <!-- TextInputLayout style for light mode -->
    <style name="Widget.PharmAlert.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/text_input_box_stroke</item>
        <item name="hintTextColor">@color/brand_600</item>
        <item name="android:textColorHint">@color/gray_500</item>
    </style>

    <style name="TextAppearance.PharmAlert.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/brand_700</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.PharmAlert.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/gray_700</item>
    </style>

    <style name="Widget.PharmAlert.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/brand_600</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.PharmAlert.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
    </style>

</resources>