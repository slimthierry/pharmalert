<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/gray_900">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/gray_800">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nouvelle Allergie"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/brand_400"
            android:layout_marginBottom="20dp" />

        <!-- Patient IPP -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPatientIpp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IPP du patient *"
            app:boxStrokeColor="@color/text_input_box_stroke"
            app:hintTextColor="@color/brand_400"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPatientIpp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_100"
                android:textColorHint="@color/gray_500"
                android:inputType="text"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Allergen Type -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAllergenType"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Type d'allergene *"
            app:boxStrokeColor="@color/text_input_box_stroke"
            app:hintTextColor="@color/brand_400"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp">

            <AutoCompleteTextView
                android:id="@+id/actvAllergenType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_100"
                android:textColorHint="@color/gray_500"
                android:inputType="none" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Allergen Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAllergenName"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Nom de l'allergene *"
            app:boxStrokeColor="@color/text_input_box_stroke"
            app:hintTextColor="@color/brand_400"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAllergenName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_100"
                android:textColorHint="@color/gray_500"
                android:inputType="text"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ATC Code -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAtcCode"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Code ATC (optionnel)"
            app:boxStrokeColor="@color/text_input_box_stroke"
            app:hintTextColor="@color/brand_400"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAtcCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_100"
                android:textColorHint="@color/gray_500"
                android:inputType="text"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Severity -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSeverity"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Severite *"
            app:boxStrokeColor="@color/text_input_box_stroke"
            app:hintTextColor="@color/brand_400"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp">

            <AutoCompleteTextView
                android:id="@+id/actvSeverity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_100"
                android:textColorHint="@color/gray_500"
                android:inputType="none" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Reaction Type -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilReactionType"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Type de reaction *"
            app:boxStrokeColor="@color/text_input_box_stroke"
            app:hintTextColor="@color/brand_400"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etReactionType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_100"
                android:textColorHint="@color/gray_500"
                android:inputType="text"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Confirmed -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbConfirmed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Confirmee par tests"
            android:textColor="@color/gray_200" />

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/red_500"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Annuler" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Creer"
                app:backgroundTint="@color/brand_600" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>